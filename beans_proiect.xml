<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context"
    xsi:schemaLocation="http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
    http://www.springframework.org/schema/context
    http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <context:component-scan base-package="proiect2" />

    <bean id="auto1" class="proiect2.Autovehicle">
        <property name="price" value="15000" />
        <property name="maxSpeed" value="200" />
        <property name="brand" value="VW" />
        <property name="year" value="2018" />
    </bean>

    <bean id="auto2" class="proiect2.Autovehicle">
        <property name="price" value="45000" />
        <property name="maxSpeed" value="240" />
        <property name="brand" value="BMW" />
        <property name="year" value="2022" />
    </bean>

    <bean id="truck1" class="proiect2.Truck">
        <constructor-arg value="80000" /> <constructor-arg value="110" />   <constructor-arg value="20000" /> </bean>

    <bean id="truck2" class="proiect2.Truck">
        <constructor-arg value="95000" />
        <constructor-arg value="120" />
        <constructor-arg value="25000" />
    </bean>

</beans>